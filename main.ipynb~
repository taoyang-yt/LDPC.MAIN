        "\n",
        "class StateInit(Layer):\n",
        "    r\"\"\"\n",
        "    Network initializing the state tensor for each user.\n",
        "    \"\"\"\n",
        "    def __init__(   self,\n",
        "                    d_s,\n",
        "                    num_units,\n",
        "                    layer_type=\"sepconv\",\n",
        "                    dtype=tf.float32,\n",
        "                    **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        if layer_type==\"sepconv\":\n",
        "            layer = SeparableConv2D\n",
        "        elif layer_type==\"conv\":\n",
        "            layer = Conv2D\n",
        "        else:\n",
        "            raise NotImplementedError(\"Unknown layer_type selected.\")\n",
        "\n",
        "        self._hidden_conv = [layer(n, (3,3), padding='same', activation='relu', dtype=dtype) for n in num_units]\n",
        "        self._output_conv = layer(d_s, (3,3), activation=None, padding='same', dtype=dtype)\n",
        "\n",
        "    def call(self, inputs):\n",
        "        y, pe, h_hat = inputs\n",
        "        batch_size = tf.shape(y)[0]\n",
        "        num_streams = tf.shape(pe)[0]\n",
        "\n",
        "        y = tf.tile(tf.expand_dims(y, axis=1), [1, num_streams, 1, 1, 1])\n",
        "        y = flatten_dims(y, 2, 0)\n",
        "\n",
        "        pe = tf.tile(tf.expand_dims(pe, axis=0), [batch_size, 1, 1, 1, 1])\n",
        "        pe = flatten_dims(pe, 2, 0)\n",
        "\n",
        "        if h_hat is not None:\n",
        "            h_hat = flatten_dims(h_hat, 2, 0)\n",
        "            z = tf.concat([y, pe, h_hat], axis=-1)\n",
        "        else:\n",
        "            z = tf.concat([y, pe], axis=-1)\n",
        "\n",
        "        for conv in self._hidden_conv:\n",
        "            z = conv(z)\n",
        "        z = self._output_conv(z)\n",
        "        return split_dim(z, [batch_size, num_streams], 0)\n",
        "\n",
        "class AggregateUserStates(Layer):\n",
        "    def __init__(   self,\n",
        "                    d_s,\n",
        "                    num_units,\n",
        "                    layer_type=\"dense\",\n",
        "                    dtype=tf.float32,\n",
        "                    **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        if layer_type!=\"dense\":\n",
        "            raise NotImplementedError(\"Unknown layer_type selected.\")\n",
        "        self._hidden_layers = [Dense(n, activation='relu', dtype=dtype) for n in num_units]\n",
        "        self._output_layer = Dense(d_s, activation=None, dtype=dtype)\n",
        "\n",
        "    def call(self, inputs):\n",
        "        s, active_tx = inputs\n",
        "        sp = s\n",
        "        for layer in self._hidden_layers:\n",
        "            sp = layer(sp)\n",
        "        sp = self._output_layer(sp)\n",
        "        active_tx_expanded = expand_to_rank(active_tx, tf.rank(sp), axis=-1)\n",
        "        sp = tf.multiply(sp, active_tx_expanded)\n",
        "        a = tf.reduce_sum(sp, axis=1, keepdims=True) - sp\n",
        "        p = tf.reduce_sum(active_tx_expanded, axis=1, keepdims=True) - 1.\n",
        "        p = tf.nn.relu(p)\n",
        "        p = tf.where(p==0., 1., tf.math.divide_no_nan(1.,p))\n",
        "        return tf.multiply(a, p)\n",
        "\n",
        "class UpdateState(Layer):\n",
        "    def __init__(   self,\n",
        "                    d_s,\n",
        "                    num_units,\n",
        "                    layer_type=\"sepconv\",\n",
        "                    dtype=tf.float32,\n",
        "                    **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        if layer_type==\"sepconv\":\n",
        "            layer = SeparableConv2D\n",
        "        elif layer_type==\"conv\":\n",
        "            layer = Conv2D\n",
        "        else:\n",
        "            raise NotImplementedError(\"Unknown layer_type selected.\")\n",
        "        self._hidden_conv = [layer(n, (3,3), padding='same', activation=\"relu\", dtype=dtype) for n in num_units]\n",
        "        self._output_conv = layer(d_s, (3,3), padding='same', activation=None, dtype=dtype)\n",
        "\n",
        "    def call(self, inputs):\n",
        "        s, a, pe = inputs\n",
        "        batch_size, num_tx = tf.shape(s)[0], tf.shape(s)[1]\n",
        "        pe_tiled = tf.tile(tf.expand_dims(pe, axis=0), [batch_size, 1, 1, 1, 1])\n",
        "        pe_flat = flatten_dims(pe_tiled, 2, 0)\n",
        "        s_flat = flatten_dims(s, 2, 0)\n",
        "        a_flat = flatten_dims(a, 2, 0)\n",
        "        z = tf.concat([a_flat, s_flat, pe_flat], axis=-1)\n",
        "        for conv in self._hidden_conv:\n",
        "            z = conv(z)\n",
        "        z = self._output_conv(z)\n",
        "        z = z + s_flat\n",
        "        return split_dim(z, [batch_size, num_tx], 0)\n",
        "\n",
        "class CGNNIt(Layer):\n",
        "    def __init__(   self,\n",
        "                    d_s,\n",
        "                    num_units_agg,\n",
        "                    num_units_state_update,\n",
        "                    layer_type_dense=\"dense\",\n",
        "                    layer_type_conv=\"sepconv\",\n",
        "                    dtype=tf.float32,\n",
        "                    **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        self._state_aggreg = AggregateUserStates(d_s, num_units_agg, layer_type_dense, dtype=dtype)\n",
        "        self._state_update = UpdateState(d_s, num_units_state_update, layer_type_conv, dtype=dtype)\n",
        "\n",
        "    def call(self, inputs):\n",
        "        s, pe, active_tx = inputs\n",
        "        a = self._state_aggreg((s, active_tx))\n",
        "        return self._state_update((s, a, pe))\n",
        "\n",
        "class ReadoutLLRs(Layer):\n",
        "    def __init__(   self,\n",
        "                    num_bits_per_symbol,\n",
        "                    num_units,\n",
        "                    layer_type=\"dense\",\n",
        "                    dtype=tf.float32,\n",
        "                    **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        if layer_type!=\"dense\":\n",
        "            raise NotImplementedError(\"Unknown layer_type selected.\")\n",
        "        self._hidden_layers = [Dense(n, activation='relu', dtype=dtype) for n in num_units]\n",
        "        self._output_layer = Dense(num_bits_per_symbol, activation=None, dtype=dtype)\n",
        "\n",
        "    def call(self, s):\n",
        "        z = s\n",
        "        for layer in self._hidden_layers:\n",
        "            z = layer(z)\n",
        "        return self._output_layer(z)\n",
        "\n",
        "class ReadoutChEst(Layer):\n",
        "    def __init__(   self,\n",
        "                    num_rx_ant,\n",
        "                    num_units,\n",
        "                    layer_type=\"dense\",\n",
        "                    dtype=tf.float32,\n",
        "                    **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        if layer_type!=\"dense\":\n",
        "            raise NotImplementedError(\"Unknown layer_type selected.\")\n",
        "        self._hidden_layers = [Dense(n, activation='relu', dtype=dtype) for n in num_units]\n",
        "        self._output_layer = Dense(2*num_rx_ant, activation=None, dtype=dtype)\n",
        "\n",
        "    def call(self, s):\n",
        "        z = s\n",
        "        for layer in self._hidden_layers:\n",
        "            z = layer(z)\n",
        "        return self._output_layer(z)\n",
        "\n",
        "class CGNN(Model):\n",
        "    def __init__(   self,\n",
        "                    num_bits_per_symbol,\n",
        "                    num_rx_ant,\n",
        "                    num_it,\n",
        "                    d_s,\n",
        "                    num_units_init,\n",
        "                    num_units_agg,\n",
        "                    num_units_state ,\n",
        "                    num_units_readout,\n",
        "                    layer_type_dense,\n",
        "                    layer_type_conv,\n",
        "                    layer_type_readout,\n",
        "                    training=False,\n",
        "                    apply_multiloss=False,\n",
        "                    dtype=tf.float32,\n",
        "                    **kwargs):\n",
        "        super().__init__(dtype=dtype,**kwargs)\n",
        "        self._training = training\n",
        "        self._apply_multiloss = apply_multiloss\n",
        "        self._s_init = StateInit(d_s, num_units_init, layer_type=layer_type_conv, dtype=dtype)\n",
        "        self._iterations = [CGNNIt(d_s, num_units_agg[i], num_units_state[i], layer_type_dense=layer_type_dense, layer_type_conv=layer_type_conv, dtype=dtype) for i in range(num_it)]\n",
        "        self._num_it = num_it\n",
        "        self._readout_llrs = ReadoutLLRs(num_bits_per_symbol, num_units_readout, layer_type=layer_type_readout, dtype=dtype)\n",
        "        self._readout_chest = ReadoutChEst(num_rx_ant, num_units_readout, layer_type=layer_type_readout, dtype=dtype)\n",
        "\n",
        "    @property\n",
        "    def num_it(self):\n",
        "        return self._num_it\n",
        "\n",
        "    @num_it.setter\n",
        "    def num_it(self, val):\n",
        "        assert (val >= 1) and (val <= len(self._iterations)), \"Invalid number of iterations\"\n",
        "        self._num_it = val\n",
        "\n",
        "    def call(self, inputs):\n",
        "        y, pe, h_hat, active_tx = inputs\n",
        "        # 功率归一化\n",
        "        norm_scaling = tf.math.divide_no_nan(1., tf.sqrt(tf.reduce_mean(tf.square(y), axis=(1,2,3), keepdims=True)))\n",
        "        y = y * norm_scaling\n",
        "        if h_hat is not None:\n",
        "            norm_scaling_expanded = expand_to_rank(norm_scaling, tf.rank(h_hat), axis=1)\n",
        "            h_hat = h_hat * norm_scaling_expanded\n",
        "\n",
        "        s = self._s_init((y, pe, h_hat))\n",
        "\n",
        "        llrs, h_hats = [], []\n",
        "        for i in range(self._num_it):\n",
        "            s = self._iterations[i]([s, pe, active_tx])\n",
        "            if (self._training and self._apply_multiloss) or i == self._num_it - 1:\n",
        "                llrs.append(self._readout_llrs(s))\n",
        "                h_hats.append(self._readout_chest(s))\n",
        "        return llrs, h_hats\n",
        "\n",
        "class CGNNOFDM(Model):\n",
        "    def __init__(self,\n",
        "                 resource_grid,\n",
        "                 stream_management,\n",
        "                 num_bits_per_symbol,\n",
        "                 num_rx_ant,\n",
        "                 max_num_tx,\n",
        "                 training,\n",
        "                 apply_multiloss,\n",
        "                 num_it,\n",
        "                 d_s,\n",
        "                 num_units_init,\n",
        "                 num_units_agg,\n",
        "                 num_units_state,\n",
        "                 num_units_readout,\n",
        "                 layer_demapper,\n",
        "                 layer_type_dense,\n",
        "                 layer_type_conv,\n",
        "                 layer_type_readout,\n",
        "                 nrx_dtype,\n",
        "                 **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        self._training = training\n",
        "        self._rg = resource_grid\n",
        "        self._sm = stream_management\n",
        "        self._num_bits_per_symbol = num_bits_per_symbol\n",
        "        self._layer_demapper = layer_demapper\n",
        "        self._nrx_dtype = nrx_dtype\n",
        "        self._max_num_tx = max_num_tx\n",
        "\n",
        "        self._cgnn = CGNN(num_bits_per_symbol, num_rx_ant, num_it, d_s,\n",
        "                          num_units_init, num_units_agg, num_units_state, num_units_readout,\n",
        "                          training=training,apply_multiloss=apply_multiloss, layer_type_dense=layer_type_dense,\n",
        "                          layer_type_conv=layer_type_conv, layer_type_readout=layer_type_readout,\n",
        "                          dtype=nrx_dtype)\n",
        "\n",
        "        self._rg_demapper = ResourceGridDemapper(self._rg, self._sm)\n",
        "        if training:\n",
        "            self._bce = tf.keras.losses.BinaryCrossentropy(from_logits=True, reduction=tf.keras.losses.Reduction.NONE)\n",
        "            self._mse = tf.keras.losses.MeanSquaredError(reduction=tf.keras.losses.Reduction.NONE)\n",
        "\n",
        "        # 导频位置编码  Pre-compute positional encoding\n",
        "        rg_type = self._rg.build_type_grid()\n",
        "        pilot_ind = tf.where(rg_type==1)\n",
        "\n",
        "        pilots = flatten_last_dims(self._rg.pilot_pattern.pilots, 3)\n",
        "\n",
        "        pilots_only = tf.scatter_nd(pilot_ind, pilots, tf.shape(rg_type, out_type=tf.int64))\n",
        "        pilot_ind_sorted = [[] for _ in range(max_num_tx * self._rg.num_streams_per_tx)]\n",
        "        for p_ind in np.array(tf.where(tf.abs(pilots_only) > 1e-3)):\n",
        "            tx_idx = p_ind[0]\n",
        "            stream_idx = p_ind[1]\n",
        "            unique_stream_idx = tx_idx * self._rg.num_streams_per_tx + stream_idx\n",
        "            pilot_ind_sorted[unique_stream_idx].append(p_ind[2:])\n",
        "\n",
        "        t_ind = np.arange(self._rg.num_ofdm_symbols)\n",
        "        f_ind = np.arange(self._rg.fft_size)\n",
        "\n",
        "        num_streams_total = max_num_tx * self._rg.num_streams_per_tx\n",
        "        num_pilots_per_stream = len(pilot_ind_sorted[0]) if pilot_ind_sorted and pilot_ind_sorted[0] else 0\n",
        "        pilots_dist_time = np.zeros([num_streams_total, self._rg.num_ofdm_symbols, self._rg.fft_size, num_pilots_per_stream])\n",
        "        pilots_dist_freq = np.zeros_like(pilots_dist_time)\n",
        "\n",
        "        for stream_idx in range(num_streams_total):\n",
        "            if not pilot_ind_sorted[stream_idx]: continue\n",
        "            for i, p_ind in enumerate(pilot_ind_sorted[stream_idx]):\n",
        "                pilots_dist_time[stream_idx, :, :, i] = np.expand_dims(np.abs(p_ind[0] - t_ind), axis=1)\n",
        "                pilots_dist_freq[stream_idx, :, :, i] = np.expand_dims(np.abs(p_ind[1] - f_ind), axis=0)\n",
        "\n",
        "        nearest_pilot_dist_time = np.min(pilots_dist_time, axis=-1) if num_pilots_per_stream > 0 else np.zeros(pilots_dist_time.shape[:-1])\n",
        "        nearest_pilot_dist_freq = np.min(pilots_dist_freq, axis=-1) if num_pilots_per_stream > 0 else np.zeros(pilots_dist_freq.shape[:-1])\n",
        "\n",
        "        mean_time, std_time = np.mean(nearest_pilot_dist_time, axis=1, keepdims=True), np.std(nearest_pilot_dist_time, axis=1, keepdims=True)\n",
        "        nearest_pilot_dist_time = np.divide(nearest_pilot_dist_time - mean_time, std_time, where=std_time>0)\n",
        "        mean_freq, std_freq = np.mean(nearest_pilot_dist_freq, axis=2, keepdims=True), np.std(nearest_pilot_dist_freq, axis=2, keepdims=True)\n",
        "        nearest_pilot_dist_freq = np.divide(nearest_pilot_dist_freq - mean_freq, std_freq, where=std_freq>0)\n",
        "\n",
        "        nearest_pilot_dist = np.stack([nearest_pilot_dist_time, nearest_pilot_dist_freq], axis=-1)\n",
        "        self._nearest_pilot_dist = tf.transpose(tf.constant(nearest_pilot_dist, tf.float32), [0, 2, 1, 3])\n",
        "\n",
        "    def call(self, inputs):\n",
        "        if self._training:\n",
        "            y, h_hat_init, active_tx, coded_bits, h = inputs\n",
        "        else:\n",
        "            y, h_hat_init, active_tx = inputs\n",
        "\n",
        "        num_tx = tf.shape(active_tx)[1]\n",
        "        y_real_imag = tf.concat([tf.math.real(y), tf.math.imag(y)], axis=-1)\n",
        "        pe = self._nearest_pilot_dist[:num_tx * self._rg.num_streams_per_tx]\n",
        "\n",
        "        y_cast = tf.cast(y_real_imag, self._nrx_dtype)\n",
        "        pe_cast = tf.cast(pe, self._nrx_dtype)\n",
        "        h_hat_init_cast = tf.cast(h_hat_init, self._nrx_dtype) if h_hat_init is not None else None\n",
        "\n",
        "        active_streams_cast = tf.cast(active_tx, self._nrx_dtype)\n",
        "\n",
        "        llrs_iter_list, h_hats_iter_list = self._cgnn((y_cast, pe_cast, h_hat_init_cast, active_streams_cast))\n",
        "\n",
        "        # 计算并累加所有迭代的损失，当不使用监督损失时，只有最后一个输出llr和hat\n",
        "        if self._training:\n",
        "            total_loss_data = 0.0\n",
        "            total_loss_chest = 0.0\n",
        "\n",
        "            # 遍历每一次迭代的输出\n",
        "            for llrs_iter, h_hats_iter in zip(llrs_iter_list, h_hats_iter_list):\n",
        "\n",
        "                llrs_current = tf.cast(llrs_iter, tf.float32)\n",
        "                h_hat_current = tf.cast(h_hats_iter, tf.float32)\n",
        "\n",
        "                # 对当前LLR进行解映射\n",
        "                s = tf.shape(llrs_current)\n",
        "                llrs_current_reshaped = tf.reshape(llrs_current, [s[0], self._max_num_tx, self._rg.num_streams_per_tx, s[2], s[3], s[4]])\n",
        "                llr_demapped = tf.transpose(llrs_current_reshaped, [0, 1, 2, 4, 3, 5])\n",
        "                llr_demapped = self._rg_demapper(llr_demapped)[:,:self._max_num_tx]\n",
        "                llr_demapped = flatten_last_dims(llr_demapped, 2)\n",
        "\n",
        "                # 计算当前迭代的数据损失\n",
        "                loss_data = self._bce(coded_bits, llr_demapped)\n",
        "                active_mask = expand_to_rank(active_tx, tf.rank(loss_data), axis=-1)\n",
        "                loss_data = tf.reduce_mean(loss_data * active_mask)\n",
        "                total_loss_data += loss_data # 累加数据损失\n",
        "\n",
        "                # 计算当前迭代的信道估计损失\n",
        "                if h is not None:\n",
        "                    s_h_hat = tf.shape(h_hat_current)\n",
        "                    h_hat_current_reshaped = tf.reshape(h_hat_current, [s_h_hat[0], self._max_num_tx, self._rg.num_streams_per_tx, s_h_hat[2], s_h_hat[3], -1])\n",
        "                    loss_chest = self._mse(h, h_hat_current_reshaped)\n",
        "                    loss_chest = tf.reduce_mean(loss_chest)\n",
        "                    total_loss_chest += loss_chest # 累加信道损失\n",
        "\n",
        "            # 通过除以迭代次数来对总损失进行归一化（取平均）\n",
        "            num_losses = tf.cast(len(llrs_iter_list), tf.float32)\n",
        "            final_loss_data = tf.math.divide_no_nan(total_loss_data, num_losses)\n",
        "            final_loss_chest = tf.math.divide_no_nan(total_loss_chest, num_losses)\n",
        "\n",
        "            return final_loss_data, final_loss_chest\n",
        "\n",
        "        # 如果是评估模式，则只使用最后一次迭代的输出\n",
        "        else:\n",
        "            llrs_final = tf.cast(llrs_iter_list[-1], tf.float32)\n",
        "            h_hat_final = tf.cast(h_hats_iter_list[-1], tf.float32)\n",
        "\n",
        "            s = tf.shape(llrs_final)\n",
        "            llrs_final_reshaped = tf.reshape(llrs_final, [s[0], self._max_num_tx, self._rg.num_streams_per_tx, s[2], s[3], s[4]])\n",
        "\n",
        "            llr_demapped = tf.transpose(llrs_final_reshaped, [0, 1, 2, 4, 3, 5])\n",
        "            llr_demapped = self._rg_demapper(llr_demapped)[:,:self._max_num_tx]\n",
        "            llr_demapped = flatten_last_dims(llr_demapped, 2)\n",
        "\n",
        "            return llr_demapped, h_hat_final\n"
      ]
    },
