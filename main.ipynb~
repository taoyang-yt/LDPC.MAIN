        "\n",
        "def dft_matrix(n, dtype=tf.complex64):\n",
        "    \"\"\"Generates an n x n DFT matrix.\"\"\"\n",
        "    n_range = tf.range(n, dtype=dtype.real_dtype)\n",
        "    k_range = tf.range(n, dtype=dtype.real_dtype)\n",
        "    k, n_grid = tf.meshgrid(k_range, n_range)\n",
        "    angle = -2.0 * np.pi * k * n_grid / tf.cast(n, dtype=dtype.real_dtype)\n",
        "    return tf.complex(tf.cos(angle), tf.sin(angle))\n",
        "\n",
        "class Precoder(tf.keras.layers.Layer):\n",
        "    \"\"\"A simple non-coherent precoder layer using a fixed DFT-based codebook.\"\"\"\n",
        "    def __init__(self, num_streams, num_tx_ant, **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        W = dft_matrix(num_tx_ant)\n",
        "        self.W = W[:, :num_streams]\n",
        "\n",
        "        # --- FIX: Cast the float divisor to a complex dtype before division ---\n",
        "        norm_factor_float = tf.sqrt(tf.cast(num_tx_ant, self.W.dtype.real_dtype))\n",
        "        self.W /= tf.cast(norm_factor_float, self.W.dtype)\n",
        "\n",
        "    def call(self, inputs):\n",
        "        return tf.einsum('btsof,as->btaof', inputs, self.W)\n",
        "\n",
        "\n"
      ]
