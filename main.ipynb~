        "\n",
        "            num_coded_bits_decoder = self.num_code_blocks * self.n_cb\n",
        "            llr_reshaped = tf.reshape(llr[..., :num_coded_bits_decoder], [batch_size, self.num_tx, self.num_streams_per_tx, self.num_code_blocks, self.n_cb])\n",
        "            bits_hat_segmented = self.decoder(llr_reshaped)\n",
        "            bits_hat_padded = tf.reshape(bits_hat_segmented, [batch_size, self.num_tx, self.num_streams_per_tx, -1])\n",
        "            bits_hat = bits_hat_padded[..., :self.transport_block_size]\n",
        "            # #基准\n",
        "            # print(\"h_hat\",h_hat.shape)\n",
        "            # print(\"err_var\",err_var.shape)\n",
