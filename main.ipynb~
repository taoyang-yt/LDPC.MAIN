        "class SionnaLLSModel(Model):\n",
        "    def __init__(self, system, batch_size, training, apply_multiloss, channel_type, cdl_model, delay_spread, speed, cyclic_prefix_length, pilot_ofdm_symbol_indices,\n",
        "                 num_rb, num_tx, num_tx_ant, num_streams_per_tx, num_rx_ant, coderate, num_bits_per_symbol, pilot_pattern_type ,\n",
        "                 # --- parameters for the integrated neural receiver ---\n",
        "                 num_nrx_iter=3, d_s=64, num_units_init=[32], num_units_readout=[32],\n",
        "                 layer_type_dense=\"dense\", layer_type_conv=\"sepconv\", layer_type_readout=\"dense\", nrx_dtype=tf.float32):\n",
        "        # 关于网络结构的参数，影响模型的深度。num_nrx_iter=5, d_s=128, num_units_init=[256], num_units_readout=[256],\n",
        "\n",
        "        super().__init__()\n",
        "        # 仿真参数\n",
        "        self.bathsize = batch_size\n",
        "        self._system = system\n",
        "        self._training = training\n",
        "        self._apply_multiloss = apply_multiloss\n",
        "        self.channel_type = channel_type\n",
        "        self.cdl_model = cdl_model\n",
        "        self.delay_spread = delay_spread\n",
        "        self.speed = speed\n",
        "        self.cyclic_prefix_length = cyclic_prefix_length\n",
        "        self.pilot_ofdm_symbol_indices = pilot_ofdm_symbol_indices\n",
        "\n",
        "        # 网络参数\n",
        "        # self.num_nrx_iter=num_nrx_iter,\n",
        "        self.d_s=d_s\n",
        "        self.num_units_init=num_units_init\n",
        "        self.num_units_readout=num_units_readout\n",
        "\n",
        "        # self.num_units_agg = num_units_agg * self.num_nrx_iter\n",
        "        # self.num_units_state = num_units_state * self.num_nrx_iter\n",
        "\n",
        "        # 载波配置\n",
        "        self.num_rb = num_rb\n",
        "        self.num_tx = num_tx\n",
        "        self.num_tx_ant = num_tx_ant\n",
        "        self.coderate = coderate\n",
        "        self.num_bits_per_symbol = num_bits_per_symbol\n",
        "        self.carrier_frequency = 3.5e9\n",
        "\n",
        "        self.num_streams_per_tx = num_streams_per_tx\n",
        "        self.num_rx_ant = num_rx_ant\n",
        "        self.num_ofdm_symbols = 14\n",
        "        self.subcarrier_spacing = 30e3\n",
        "        self.channel_norm = True\n",
        "\n",
        "        num_subcarriers = self.num_rb * 12\n",
        "        self.fft_size = num_subcarriers\n",
        "        # 配置资源网格，没有配置保护子载波和直流子载波\n",
        "        self.resource_grid = sionna.phy.ofdm.ResourceGrid(\n",
        "            num_ofdm_symbols=self.num_ofdm_symbols,\n",
        "            fft_size=self.fft_size,\n",
        "            subcarrier_spacing=self.subcarrier_spacing,\n",
        "            num_tx=self.num_tx,\n",
        "            num_streams_per_tx=self.num_streams_per_tx,\n",
        "            num_guard_carriers=[0, 0],\n",
        "            dc_null=False,\n",
        "        )\n",
        "        # 配置DMRS导频配置方式，type1，2符号，两对，第一个导频符号在2的位置\n",
        "        dmrs_config = sionna.phy.nr.PUSCHDMRSConfig(\n",
        "            config_type=1, length=2, type_a_position=self.pilot_ofdm_symbol_indices[0],\n",
        "            additional_position=1, dmrs_port_set=list(range(self.num_streams_per_tx)),\n",
        "        )\n",
        "\n",
        "        pusch_config = sionna.phy.nr.PUSCHConfig(\n",
        "            pusch_dmrs_config=dmrs_config, num_layers=self.num_streams_per_tx,\n",
        "            num_antenna_ports=self.num_streams_per_tx, n_size_bwp=self.num_rb,\n",
        "            symbol_allocation=[0, self.num_ofdm_symbols]\n",
        "        )\n",
        "\n",
        "        self.resource_grid.pilot_pattern = sionna.phy.nr.PUSCHPilotPattern([pusch_config])\n",
        "        if not hasattr(self.resource_grid.pilot_pattern, 'data_mask'):\n",
        "            self.resource_grid.pilot_pattern.data_mask = tf.logical_not(tf.cast(self.resource_grid.pilot_pattern.mask, tf.bool))\n",
        "\n",
        "        self.sm = sionna.phy.mimo.StreamManagement(np.array([[1]]), self.num_streams_per_tx)\n",
        "        # self.remove_nulled_scs = sionna.phy.ofdm.RemoveNulledSubcarriers(self.resource_grid)\n",
        "\n",
        "        # Transmitter and receiver components\n",
        "        self.binary_source = sionna.phy.mapping.BinarySource()\n",
        "\n",
        "\n",
        "        # 资源网格分配后的用于数据符号的总数据RE数\n",
        "        num_data_re_per_stream = self.resource_grid.num_data_symbols.numpy()\n",
        "        self.num_data_re = num_data_re_per_stream\n",
        "        # 计算资源网格能承载的总编码比特数\n",
        "        num_coded_bits = int(num_data_re_per_stream * self.num_bits_per_symbol)\n",
        "        # 反向计算出总的传输块大小(总信息比特数)\n",
        "        self.transport_block_size = int(num_coded_bits * self.coderate)\n",
        "        # 单个码块(Code Block)的信息长度 k_cb\n",
        "        #    根据5G标准，LDOC支持编码长度k_cb不能超过8448\n",
        "        if self.transport_block_size > 8448:\n",
        "            k_cb = 8448\n",
        "        else:\n",
        "            # 如果总信息量小于8448，则只有一个码块，其长度就是总信息量\n",
        "            k_cb = self.transport_block_size\n",
        "\n",
        "        # 计算需要分割的码块数量\n",
        "        if self.transport_block_size == 0:\n",
        "            self.num_code_blocks = 0\n",
        "        else:\n",
        "            self.num_code_blocks = int(np.ceil(self.transport_block_size / k_cb))\n",
        "\n",
        "        # 计算单个码块编码后的长度 n_cb\n",
        "        # 确保所有编码后的码块总长度恰好等于网格容量\n",
        "        if self.num_code_blocks > 0:\n",
        "            n_cb = int(np.floor(num_coded_bits / self.num_code_blocks))\n",
        "        else:\n",
        "            n_cb = 0\n",
        "\n",
        "        # print(f\"k_cb_before: {k_cb}, n_cb_before: {n_cb}\")\n",
        "        encoder_ref = sionna.phy.fec.ldpc.LDPC5GEncoder(k_cb, n_cb)\n",
        "        self.k_cb, self.n_cb = encoder_ref.k, encoder_ref.n # 获取编码器实际使用的k和n\n",
        "\n",
        "        if self.k_cb > 0:\n",
        "            self.num_code_blocks = int(np.ceil(self.transport_block_size / self.k_cb))\n",
        "        else:\n",
        "            self.num_code_blocks = 0\n",
        "        # #打印\n",
        "        # print(f\"k_cb: {self.k_cb}, n_cb: {self.n_cb}\")\n",
        "        # print(f\"transport_block_size: {self.transport_block_size}\")\n",
        "        # print(f\"num_code_blocks: {self.num_code_blocks}\")\n",
        "        # print(f\"num_data_re: {self.num_data_re}\")\n",
        "\n",
        "\n",
        "        self.encoder = sionna.phy.fec.ldpc.LDPC5GEncoder(self.k_cb, self.n_cb)\n",
        "        self.decoder = sionna.phy.fec.ldpc.LDPC5GDecoder(self.encoder, hard_out=True)\n",
        "\n",
        "        # decoder_codeword: 用于获取完整的码字，以进行奇偶校验\n",
        "        self.decoder_codeword = sionna.phy.fec.ldpc.LDPC5GDecoder(self.encoder, hard_out=True, return_infobits=False)\n",
        "\n",
        "\n",
        "        self.mapper = sionna.phy.mapping.Mapper(\"qam\", self.num_bits_per_symbol)\n",
        "        self.demapper = sionna.phy.mapping.Demapper(\"app\", \"qam\", self.num_bits_per_symbol)\n",
        "\n",
        "        self.rg_mapper = sionna.phy.ofdm.ResourceGridMapper(self.resource_grid)\n",
        "        self.precoder = Precoder(self.num_streams_per_tx, self.num_tx_ant)\n",
        "        # Channel Model Setup\n",
        "        if self.channel_type.lower() == 'cdl':\n",
        "            bs_array = sionna.phy.channel.tr38901.AntennaArray(num_rows=1, num_cols=self.num_rx_ant, polarization=\"single\", polarization_type=\"V\", antenna_pattern=\"omni\", carrier_frequency=self.carrier_frequency)\n",
        "            ut_array = sionna.phy.channel.tr38901.AntennaArray(num_rows=1, num_cols=self.num_tx_ant, polarization=\"single\", polarization_type=\"V\", antenna_pattern=\"omni\", carrier_frequency=self.carrier_frequency)\n",
        "            self.channel_model = sionna.phy.channel.tr38901.CDL(model=self.cdl_model, delay_spread=self.delay_spread, carrier_frequency=self.carrier_frequency, ut_array=ut_array, bs_array=bs_array, direction=\"uplink\", min_speed=self.speed)\n",
        "        elif self.channel_type in (\"UMi\", \"UMa\"):\n",
        "            ut_array = sionna.phy.channel.tr38901.PanelArray(num_rows_per_panel=1, num_cols_per_panel=self.num_tx_ant, polarization='single', polarization_type='V', antenna_pattern='omni', carrier_frequency=self.carrier_frequency)\n",
        "            num_cols_per_panel_bs, polarization_bs, polarization_type_bs = (1, \"single\", 'V') if self.num_rx_ant == 1 else (self.num_rx_ant // 2, \"dual\", 'cross')\n",
        "            bs_array = sionna.phy.channel.tr38901.PanelArray(num_rows_per_panel=1, num_cols_per_panel=num_cols_per_panel_bs, polarization=polarization_bs, polarization_type=polarization_type_bs, antenna_pattern='38.901', carrier_frequency=self.carrier_frequency)\n",
        "            channel_args = {\"carrier_frequency\": self.carrier_frequency, \"o2i_model\": 'low', \"bs_array\": bs_array, \"ut_array\": ut_array, \"direction\": 'uplink', \"enable_pathloss\": False, \"enable_shadow_fading\": False}\n",
        "            self.channel_model = sionna.phy.channel.tr38901.UMi(**channel_args) if self.channel_type == \"UMi\" else sionna.phy.channel.tr38901.UMa(**channel_args)\n",
        "            #设置空间拓扑关系\n",
        "            topology = sionna.phy.channel.gen_single_sector_topology(self.bathsize, self.num_tx, self.channel_type.lower())\n",
        "            self.channel_model.set_topology(*topology)\n",
        "        else:\n",
        "            raise ValueError(f\"Unsupported channel_type: {self.channel_type}\")\n",
        "\n",
        "        self.channel = sionna.phy.channel.OFDMChannel(self.channel_model, self.resource_grid, add_awgn=True, normalize_channel=self.channel_norm, return_channel=True)\n",
        "\n",
        "        # Receiver Setup\n",
        "        if \"baseline\" in self._system:\n",
        "            self.ls_estimator = LSChannelEstimator(self.resource_grid, interpolation_type=\"nn\")\n",
        "            self.lmmse_equalizer = sionna.phy.ofdm.LMMSEEqualizer(self.resource_grid, self.sm)\n",
        "\n",
        "\n",
        "        elif self._system == \"neural-receiver\":\n",
        "            self.ls_estimator = LSChannelEstimator(self.resource_grid, interpolation_type=\"nn\")\n",
        "            # Use dynamic lists for num_units_agg and num_units_state\n",
        "            num_units_agg = [[64]] * num_nrx_iter  #64\n",
        "            num_units_state = [[128]] * num_nrx_iter\n",
        "\n",
        "            self._cgnn_ofdm = CGNNOFDM(\n",
        "                resource_grid=self.resource_grid,\n",
        "                stream_management=self.sm,\n",
        "                num_bits_per_symbol=self.num_bits_per_symbol,\n",
        "                num_rx_ant=self.num_rx_ant,\n",
        "                max_num_tx=self.num_tx,\n",
        "                training=self._training,\n",
        "                apply_multiloss=self._apply_multiloss,\n",
        "\n",
        "                num_it=num_nrx_iter,\n",
        "                d_s=self.d_s,\n",
        "                num_units_init=self.num_units_init,\n",
        "                num_units_agg=num_units_agg,\n",
        "                num_units_state=num_units_state,\n",
        "                num_units_readout=self.num_units_readout,\n",
        "\n",
        "                layer_demapper=None,\n",
        "                layer_type_dense=layer_type_dense,\n",
        "                layer_type_conv=layer_type_conv,\n",
        "                layer_type_readout=layer_type_readout,\n",
        "                nrx_dtype=nrx_dtype\n",
        "            )\n",
        "\n",
        "\n",
        "\n",
        "    def estimate_channel(self, y, no):\n",
        "        h_hat, _ = self.ls_estimator(y, no)\n",
        "        h_hat = h_hat[:, 0, :, 0, :, :, :]\n",
        "        h_hat = tf.transpose(h_hat, [0, 2, 4, 3, 1])\n",
        "        return tf.concat([tf.math.real(h_hat), tf.math.imag(h_hat)], axis=-1)\n",
        "\n",
        "    def preprocess_channel_ground_truth(self, h):\n",
        "        h_eff = tf.einsum('brRtaof,as->brRtsof', h, self.precoder.W)\n",
        "        h_eff = h_eff[:, 0, :, 0, :, :, :]\n",
        "        h_eff = tf.transpose(h_eff, [0, 2, 4, 3, 1])\n",
        "        return tf.concat([tf.math.real(h_eff), tf.math.imag(h_eff)], axis=-1)\n",
        "\n",
        "    def call(self, ebno_db, training=False):\n",
        "        batch_size = tf.shape(ebno_db)[0]\n",
        "        # batch_size = tf.shape(ebno_db)[0]\n",
        "        no = sionna.phy.utils.ebnodb2no(ebno_db, self.num_bits_per_symbol, self.coderate, self.resource_grid)\n",
        "        #生成传输块总信息比特大小（可能会大于8448）\n",
        "        bits = self.binary_source([batch_size, self.num_tx, self.num_streams_per_tx, self.transport_block_size])\n",
        "        # 对最后一个码块需要额外填充，计算需要填充的数目，8448*(tb_n)-总传输信息比特数\n",
        "        padding_size = (self.num_code_blocks * self.k_cb) - self.transport_block_size\n",
        "        # 填充后的符合LDPC最大长度8448的比特流\n",
        "        bits_padded = tf.pad(bits, [[0, 0]] * 3 + [[0, padding_size]])\n",
        "        # 分割成传输块数目的8448的信息比特\n",
        "        bits_segmented = tf.reshape(bits_padded, [batch_size, self.num_tx, self.num_streams_per_tx, self.num_code_blocks, self.k_cb])\n",
        "        # 将最大8448的信息比特传入LDPC编码器\n",
        "        coded_bits_reshaped = self.encoder(bits_segmented)\n",
        "\n",
        "        num_coded_bits = self.num_code_blocks * self.n_cb\n",
        "        # 将LDPC编码比特展平成一个比特流\n",
        "        coded_bits_flat = tf.reshape(coded_bits_reshaped, [batch_size, self.num_tx, self.num_streams_per_tx, num_coded_bits])\n",
        "        num_bits_capacity_per_stream = self.num_data_re * self.num_bits_per_symbol\n",
        "        coded_bits_for_mapper = coded_bits_flat[..., :num_bits_capacity_per_stream]\n",
        "        x_data = self.mapper(coded_bits_for_mapper)\n",
        "        x_rg = self.rg_mapper(x_data)\n",
        "        x_precoded = self.precoder(x_rg)\n",
        "\n",
        "        y_rg, h_freq = self.channel(x_precoded, no)\n",
        "        # #基准\n",
        "        # print(\"no\",no.shape)\n",
        "        # print(\"bits\",bits.shape)\n",
        "        # print(\"bits_padded\",bits_padded.shape)\n",
