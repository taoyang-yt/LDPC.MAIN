        "def plot_results(sim_params):\n",
        "    \"\"\"\n",
        "    根据仿真结果绘制BER和BLER性能对比图。\n",
        "\n",
        "    Args:\n",
        "        sim_params (dict): 包含仿真参数和结果的字典。\n",
        "    \"\"\"\n",
        "    # 获取信道和配置信息用于图表标题\n",
        "    channel_type = sim_params.get(\"channel_type\", \"Unknown Channel\")\n",
        "    num_rb = sim_params.get(\"num_rb\", \"N/A\")\n",
        "    num_bits_per_symbol = sim_params.get(\"num_bits_per_symbol\", \"N/A\")\n",
        "    coderate_val = int(sim_params.get(\"coderate\", 0) * 1024)\n",
        "\n",
        "    # 创建一个图和两个子图 (一个用于BLER, 一个用于BER)\n",
        "    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(18, 7))\n",
        "    fig.suptitle(f\"Performance Comparison | Channel: {channel_type} | RB: {num_rb} | BPS: {num_bits_per_symbol} | Coderate: {coderate_val}/1024\", fontsize=16)\n",
        "\n",
        "    # --- 绘制 BLER (误块率) 对比图 ---\n",
        "    ax1.set_title(\"BLER Performance\")\n",
        "    ax1.set_xlabel(r\"$E_b/N_0$ (dB)\")\n",
        "    ax1.set_ylabel(\"Block Error Rate (BLER)\")\n",
        "    ax1.set_yscale('log') # Y轴使用对数刻度\n",
        "    ax1.grid(which=\"both\")\n",
        "\n",
        "    # 检查并绘制基准LS估计的结果\n",
        "    baseline_bler_key = \"baseline-ls-estimation-dmrs\"\n",
        "    if baseline_bler_key in sim_params[\"results\"] and sim_params[\"results\"][baseline_bler_key][\"bler\"]:\n",
        "        # 结果是以列表形式存储\n",
        "        bler_data = sim_params[\"results\"][baseline_bler_key][\"bler\"][0]\n",
        "        ebno_range = sim_params[\"ebno_db\"][:len(bler_data)]\n",
        "        ax1.plot(ebno_range, bler_data,\n",
        "                 label='Baseline LS Estimation (DMRS)',\n",
        "                 linestyle='--', marker='s', color='C0')\n",
        "\n",
        "    # 检查并绘制神经接收机的结果\n",
        "    nr_bler_key = \"neural-receiver\"\n",
        "    if nr_bler_key in sim_params[\"results\"] and sim_params[\"results\"][nr_bler_key][\"bler\"]:\n",
        "\n",
        "        bler_data = sim_params[\"results\"][nr_bler_key][\"bler\"][0]\n",
        "        ebno_range = sim_params[\"ebno_db\"][:len(bler_data)]\n",
        "        ax1.plot(ebno_range, bler_data,\n",
        "                 label='Neural Receiver',\n",
        "                 linestyle='-', marker='o', color='C1')\n",
        "\n",
        "    ax1.legend()\n",
        "    ax1.set_ylim(1e-5, 1.1) # 设置Y轴范围\n",
        "\n",
        "    # --- 绘制 BER (误比特率) 对比图 ---\n",
        "    ax2.set_title(\"BER Performance\")\n",
        "    ax2.set_xlabel(r\"$E_b/N_0$ (dB)\")\n",
