        "\n",
        "\n",
        "# 设置 training=True 来启动训练\n",
        "training_is_active = True\n",
        "\n",
        "if training_is_active:\n",
        "    # 实例化为训练模式的端到端系统\n",
        "    model_train = SionnaLLSModel(\n",
        "            system='neural-receiver',\n",
        "            training=True,\n",
        "            apply_multiloss=False,\n",
        "            batch_size=SIM_PARAMS[\"batch_size\"],\n",
        "            channel_type=SIM_PARAMS[\"channel_type\"],       #cdl，UMa，UMi\n",
        "            cdl_model=\"C\",\n",
        "            delay_spread=SIM_PARAMS[\"delay_spread\"],\n",
        "            speed=SIM_PARAMS[\"speed\"],\n",
        "            cyclic_prefix_length=SIM_PARAMS[\"cyclic_prefix_length\"],\n",
        "            pilot_ofdm_symbol_indices=SIM_PARAMS[\"pilot_ofdm_symbol_indices\"],\n",
        "            num_rb=SIM_PARAMS[\"num_rb\"],\n",
        "            num_tx=SIM_PARAMS[\"num_tx\"],\n",
        "            num_tx_ant=SIM_PARAMS[\"num_tx_ant\"],\n",
        "            num_streams_per_tx=SIM_PARAMS[\"num_streams_per_tx\"],\n",
        "            num_rx_ant=SIM_PARAMS[\"num_rx_ant\"],\n",
        "            coderate=SIM_PARAMS[\"coderate\"],\n",
        "            num_bits_per_symbol=SIM_PARAMS[\"num_bits_per_symbol\"],\n",
        "            pilot_pattern_type='dmrs',\n",
        "            # 网络参数\n",
        "            num_nrx_iter=NRX_PARAMS[\"num_nrx_iter\"],\n",
        "            d_s=NRX_PARAMS[\"d_s\"],\n",
        "            num_units_init=NRX_PARAMS[\"num_units_init\"],\n",
        "            num_units_readout=NRX_PARAMS[\"num_units_readout\"],\n",
        "\n",
        "        )\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "    # 创建ADAM优化器\n",
        "    optimizer = tf.keras.optimizers.Adam()\n",
        "    # 创建空模型，并设置权重， 调用 train_step 来触发 tracing 和权重创建\n",
        "    print(\"正在构建空模型，并创建权重...\")\n",
        "    dummy_ebno_batch = tf.zeros([SIM_PARAMS[\"batch_size\"]], dtype=tf.float32)\n",
        "    _ = model_train.train_step(dummy_ebno_batch)\n",
        "    print(\"模型构建完成。\")\n",
        "\n",
        "\n",
        "    print(\"开始训练神经接收机...\")\n",
        "\n",
        "      # 训练循环\n",
        "    for i in range(TRAIN_PARAMS[\"num_training_iterations\"]):\n",
        "        ebno_db_batch = tf.random.uniform(shape=[SIM_PARAMS[\"batch_size\"]],\n",
        "                                          minval=TRAIN_PARAMS[\"ebno_db_min\"],\n",
        "                                          maxval=TRAIN_PARAMS[\"ebno_db_max\"])\n",
        "        with tf.GradientTape() as tape:\n",
        "             total_loss, loss_data, loss_chest = model_train.train_step(ebno_db_batch)\n",
        "        # 计算梯度\n",
        "        trainable_weights = model_train._cgnn_ofdm.trainable_weights\n",
        "        grads = tape.gradient(total_loss, trainable_weights)\n",
        "        norm_grads= tf.linalg.global_norm(grads) #范数归一化\n",
        "        # 梯度裁剪 (Gradient Clipping)\n",
        "        # clipped_grads, _ = tf.clip_by_global_norm(grads, 1.0)\n",
        "        # 应用梯度来更新权重\n",
        "        optimizer.apply_gradients(zip(grads, trainable_weights))\n",
        "\n",
        "        # 监控和打印日志\n",
        "        if i % 100 == 0: # 每10次迭代打印一次日志\n",
        "          avg_ebno = tf.reduce_mean(ebno_db_batch)\n",
        "          log_msg = (\n",
        "              f\"迭代 {i:>5}/{TRAIN_PARAMS['num_training_iterations']} | \"\n",
        "              f\"Avg Eb/No: {avg_ebno.numpy():>5.2f} dB | \"\n",
        "              f\"Total Loss: {total_loss.numpy():<8.6f} | \"\n",
        "              f\"Data Loss: {loss_data.numpy():<8.6f} | \"\n",
        "              # f\"Channel Loss: {loss_chest.numpy():<8.6f}  |  \"\n",
        "              f\"global_norm_grads: {norm_grads:<8.6f}\"\n",
        "          )\n",
        "          print(log_msg)\n",
        "\n",
        "    # 保存训练好的权重\n",
        "    print(\"\\n训练完成，正在保存权重...\")\n",
        "    # 从 model_train.neural_receiver 获取权重，因为优化器只更新了这部分的权重\n",
        "    trained_weights = model_train._cgnn_ofdm.get_weights()\n",
        "    model_train._cgnn_ofdm.summary(line_length=120)\n",
        "    with open(TRAIN_PARAMS[\"model_weights_path\"], 'wb') as f:\n",
        "        pickle.dump(trained_weights, f)\n",
        "    print(f\"权重已保存至 {TRAIN_PARAMS['model_weights_path']}。\")\n"
      ]
    },
