        "\n",
        "return_check_output = True # 控制\n",
        "\n",
        "if return_check_output:\n",
        "    # --- 评估神经接收机 ---\n",
        "    print(\"\\n评估神经接收机模型的校验和数据流输出...\")\n",
        "    try:\n",
        "        with open(TRAIN_PARAMS[\"model_weights_path\"], 'rb') as f:\n",
        "            weights = pickle.load(f)\n",
        "        print(\"成功加载已训练的权重。\")\n",
        "\n",
        "        # for cdl_model in SIM_PARAMS[\"cdl_model\"]:\n",
        "            # print(f\"  Simulating CDL Model: {cdl_model}\")\n",
        "            # 在循环内实例化模型以确保每次仿真的信道都正确\n",
        "        model_check_output = SionnaLLSModel(\n",
        "            system='neural-receiver',\n",
        "            training=False,\n",
        "            apply_multiloss=False,\n",
        "            batch_size=SIM_PARAMS[\"batch_size\"],\n",
        "            channel_type=SIM_PARAMS[\"channel_type\"],       #cdl，UMa，UMi\n",
        "            cdl_model=\"C\",\n",
        "            delay_spread=SIM_PARAMS[\"delay_spread\"],\n",
        "            speed=SIM_PARAMS[\"speed\"],\n",
        "            cyclic_prefix_length=SIM_PARAMS[\"cyclic_prefix_length\"],\n",
        "            pilot_ofdm_symbol_indices=SIM_PARAMS[\"pilot_ofdm_symbol_indices\"],\n",
        "            num_rb=SIM_PARAMS[\"num_rb\"],\n",
        "            num_tx=SIM_PARAMS[\"num_tx\"],\n",
        "            num_tx_ant=SIM_PARAMS[\"num_tx_ant\"],\n",
        "            num_streams_per_tx=SIM_PARAMS[\"num_streams_per_tx\"],\n",
        "            num_rx_ant=SIM_PARAMS[\"num_rx_ant\"],\n",
        "            coderate=SIM_PARAMS[\"coderate\"],\n",
        "            num_bits_per_symbol=SIM_PARAMS[\"num_bits_per_symbol\"],\n",
        "            pilot_pattern_type='dmrs',\n",
        "            # 网络参数\n",
        "            num_nrx_iter=NRX_PARAMS[\"num_nrx_iter\"],\n",
        "            d_s=NRX_PARAMS[\"d_s\"],\n",
        "            num_units_init=NRX_PARAMS[\"num_units_init\"],\n",
        "            num_units_readout=NRX_PARAMS[\"num_units_readout\"],\n",
        "\n",
        "        )\n",
        "\n",
        "        # 创建空模型，并设置权重\n",
        "        print(\"正在构建空模型，并设置权重...\")\n",
        "        dummy_ebno = tf.zeros([SIM_PARAMS[\"batch_size\"]], dtype=tf.float32)\n",
        "        _ = model_check_output(dummy_ebno)\n",
        "        model_check_output._cgnn_ofdm.set_weights(weights)\n",
        "        print(\"模型构建完成。\")\n",
        "\n",
        "\n",
        "        print(\"执行一次前向传播...\")\n",
        "        ebno_db_value=10.0\n",
        "        ebno_db_tensor = tf.fill([SIM_PARAMS[\"batch_size\"]], ebno_db_value)\n",
        "        bits, bits_hat= model_check_output(ebno_db_tensor)\n",
        "\n",
        "        print(\"\\n--- 评估完成 ---\")\n",
        "\n",
        "        bits_np = bits.numpy()\n",
        "        bits_hat_np = bits_hat.numpy()\n",
        "\n",
        "        # 计算整个批次的平均BER和BLER\n",
        "        ber = np.mean(np.abs(bits_np - bits_hat_np))\n",
        "        reduce_axes = tuple(range(1, bits_np.ndim))\n",
        "        error_per_sample = np.any(np.abs(bits_np - bits_hat_np) > 0, axis=reduce_axes)\n",
        "        bler = np.mean(error_per_sample)\n",
        "        print(f\"本批的平均 BER: {ber:.6f}, 平均 BLER: {bler:.4f}\")\n",
        "        print(\"-\" * 50)\n",
        "\n",
        "\n",
        "        print(\"--- 解码校验结果和数据流详细输出 ---\")\n",
        "\n",
        "        # 提取第一个样本的数据\n",
        "        first_sample_bits = bits_np[0].reshape(-1, bits_np.shape[-1])\n",
        "        first_sample_bits_hat = bits_hat_np[0].reshape(-1, bits_hat_np.shape[-1])\n",
        "        # 遍历第一个样本中的每个数据流\n",
        "        for i in range(first_sample_bits.shape[0]):\n",
        "            print(f\"数据流 {i+1}:\")\n",
        "\n",
        "            # 比较原始比特和解码比特\n",
        "            stream_has_errors = np.any(np.abs(first_sample_bits[i] - first_sample_bits_hat[i]) > 0)\n",
        "            check_result = \"正确 \" if not stream_has_errors else \"错误 \"\n",
        "\n",
        "            print(f\"  解码校验结果: {check_result}\")\n",
        "            print(f\"  原始比特流 (前100位): {first_sample_bits[i, :100]}\")\n",
        "            print(f\"  解码比特流 (前100位): {first_sample_bits_hat[i, :100]}\")\n",
        "            print(\"-\" * 50)\n",
        "        model_check_output._cgnn_ofdm.summary(line_length=80)\n",
        "        model_check_output.summary(line_length=80)\n",
        "    except FileNotFoundError:\n",
        "        print(f\"  错误：找不到权重文件 {TRAIN_PARAMS['model_weights_path']}。请先运行训练模块。\")\n",
        "\n"
